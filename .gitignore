# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — RV32I 5-stage pipeline core
# ─────────────────────────────────────────────────────────────────────────────

# ── Personal development notes ───────────────────────────────────────────────
progress.md

# ── External test suite (too large to track; clone separately) ───────────────
# git clone https://github.com/riscv-software-src/riscv-tests.git
riscv-tests/

# ── Simulation build artifacts (regenerated by iverilog / vvp) ───────────────
sim/*.vvp
sim/simv

# ── Temporary hex loaded per test run (overwritten by run_riscv_tests.sh) ────
sim/test.hex

# ── VCD waveform dumps (+WAVE plusarg) ───────────────────────────────────────
sim/*.vcd
*.vcd

# ── riscv-tests compiled outputs (regenerated by run_riscv_tests.sh) ─────────
tests/out/

# ── Debug / intermediate hex files from development ──────────────────────────
sim/fib_dbg.hex
sim/fib_mini.hex
sim/fib_unrolled.hex
sim/loop_test.hex

# ── Vivado generated project directories (run tcl scripts to regenerate) ─────
vivado/create_axi_project.tcl


# ── Claude Code local settings ───────────────────────────────────────────────
.claude/

# ── macOS metadata ────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
